# ---------------------------------------------------------------
#  MLOps Module 3 — .gitignore
# ---------------------------------------------------------------

# ----- Secrets: never commit private keys -----
*.pem
*.ppk
*.p12
*.key

# ----- Python -----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.ipynb_checkpoints/
*.egg-info/

# ----- Instructor-only material (NOT for student-facing repo) -----
# The Manual Provisioning goldmine contains boto3 helpers + a step-by-step
# Manual_AWS_Provisioning.md doc that walks instructors through how to
# build the AWS environment from scratch. Kept local, not shipped to learners.
labs/M3_LabB_Manual_Provisioning/
labs/M3_Manual_Provisionin_AWS_Resources/

# Old-name Streamlit folders from earlier renumbering passes -- kept
# gitignored in case they reappear locally. The current tracked folder is
# labs/M3_Lab_E_Streamlit_Deployment/.
labs/M3_LabE_Streamlit_Batch/
labs/M3_Lab_D_Streamlit_Batch/

# ----- Lab artifacts generated at runtime -----
# (Boto3 helper scripts in labs/M3_LabB_Manual_Provisioning/ write this file
#  with real AWS resource IDs — keep it local, never commit.)
outputs.json

# Streamlit / Lab E runtime logs
labs/M3_Lab_E_Streamlit_Deployment/logs.log
*.log

# (labs/simple_streamlit_app/ was previously gitignored; now tracked — students
#  use it as a self-contained "load these .pkl files and serve predictions" demo.)

# ----- OS / IDE junk -----
.DS_Store
Thumbs.db
desktop.ini
~$*
.vscode/
.idea/
*.swp
*~
.OneDrive*

# --- Nakoba / session-specific secrets ---
# *.pem and *.key already covered above; extras below:
*-key.pem
*.json.bak
codepipeline-policy.json
codebuild-trust-policy.json
ecs-trust-policy.json
/tmp/
.env
*.secret
